# ==========================================
# Telegram Bot Configuration
# ==========================================

BOT_TOKEN=1234567890:YOUR_BOT_TOKEN_HERE

# ==========================================
# PostgreSQL (Neon Database)
# Example:
# postgresql://username:password@host/dbname?sslmode=require
# ==========================================

DATABASE_URL=postgresql://username:password@ep-example.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ==========================================
# Bot Owner (Telegram User ID)
# Only this user can manage the bot.
# ==========================================

OWNER_ID=123456789

# ==========================================
# Logging
# DEBUG / INFO / WARNING / ERROR
# ==========================================

LOG_LEVEL=INFO
